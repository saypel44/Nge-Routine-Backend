# ── Local development .env ──
# Copy this to .env and fill in your values.
# Railway injects MYSQLHOST, MYSQLPORT, etc. automatically — no need to set them there.

# Database (local dev)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=quick_tracker

# JWT secret — use a long random string in production
JWT_SECRET=replace_with_a_long_random_secret_string

# Optional: URL of your deployed frontend (for CORS)
FRONTEND_URL=http://localhost:5500

# Set to "true" if your MySQL host requires SSL
DB_SSL=false
